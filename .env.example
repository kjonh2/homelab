# =============================================================================
# HOMELAB — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# DOMAIN
# -----------------------------------------------------------------------------
DOMAIN=iknowu.org
TRAEFIK_DOMAIN=traefik.iknowu.org
TRAEFIK_ACME_EMAIL=admin@iknowu.org

# Traefik dashboard credentials (user:password)
# Generate with: htpasswd -nb admin yourpassword
# Or use: echo $(htpasswd -nb admin yourpassword) | sed -e s/\\$/\\$\\$/g
TRAEFIK_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# -----------------------------------------------------------------------------
# DATABASES
# -----------------------------------------------------------------------------
POSTGRES_DB=homelab
POSTGRES_USER=homelab_user
POSTGRES_PASSWORD=change_me_to_a_strong_password

MONGO_USER=homelab_user
MONGO_PASSWORD=change_me_to_a_strong_password
MONGO_DB=homelab

REDIS_PASSWORD=change_me_to_a_strong_password

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change_me

# -----------------------------------------------------------------------------
# TIMEZONE
# -----------------------------------------------------------------------------
TZ=Europe/London

# -----------------------------------------------------------------------------
# OPTIONAL — API Keys (uncomment as needed)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxx
# TAVILY_API_KEY=tvly-xxxxxxxxxxxx
# OPENWEATHER_API_KEY=xxxxxxxxxxxx
